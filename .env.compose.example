POSTGRES_DB=duck_web
POSTGRES_USER=duck_web
POSTGRES_PASSWORD=change-me-to-a-strong-postgres-password
POSTGRES_PORT=5432

APP_PORT=3000
DATABASE_URL=postgresql://duck_web:change-me-to-a-strong-postgres-password@postgres:5432/duck_web?schema=public
DUCKMAIL_API_BASE_URL=https://api.duckmail.sbs
ADMIN_USERNAME=admin
# 使用 `node scripts/hash-password.mjs "your-password"` 生成
ADMIN_PASSWORD_HASH=\$argon2id\$v=19\$m=65536,t=3,p=4\$replace\$replace
APP_ENCRYPTION_KEY=change-me-to-a-long-random-secret
SESSION_SECRET=change-me-to-another-long-random-secret
RELAY_API_TOKEN=change-me-to-a-relay-api-token
