{
  "name": "duckmail-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/run-next.mjs dev",
    "prisma:generate": "prisma generate",
    "prisma:generate:prod": "prisma generate --schema prisma/schema.postgres.prisma",
    "build": "npm run prisma:generate && node ./scripts/run-next.mjs build",
    "build:prod": "npm run prisma:generate:prod && node ./scripts/run-next.mjs build",
    "start": "node ./scripts/run-next.mjs start",
    "lint": "tsc --noEmit",
    "db:push": "npm run db:push:dev",
    "db:push:dev": "prisma db push",
    "db:push:prod": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:studio": "prisma studio",
    "postinstall": "npm run prisma:generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "argon2": "^0.41.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
